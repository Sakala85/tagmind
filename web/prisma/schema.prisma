generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts        Account[]
  sessions        Session[]
  auditReports    AuditReport[]
  containers      UserContainer[]
  serverTemplates ServerTemplate[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Custom models
model AuditReport {
  id             String   @id @default(cuid())
  userId         String
  accountId      String
  containerId    String
  containerName  String
  score          Int
  totalTags      Int      @default(0)
  totalTriggers  Int      @default(0)
  totalVariables Int      @default(0)
  criticalIssues Int      @default(0)
  warnings       Int      @default(0)
  infos          Int      @default(0)
  issues         String   // JSON string of issues array
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([containerId])
}

model UserContainer {
  id            String   @id @default(cuid())
  userId        String
  accountId     String
  accountName   String
  containerId   String
  containerName String
  addedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, containerId])
  @@index([userId])
}

// Server Templates (uploaded GTM container JSON exports)
model ServerTemplate {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  fileName    String
  content     String   // Full JSON content
  constants   String   // JSON array of {name, placeholder} constant variables found in template
  tagCount    Int      @default(0)
  triggerCount Int     @default(0)
  variableCount Int   @default(0)
  clientCount  Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// GTM Cache Models
model GTMAccountCache {
  id           String   @id @default(cuid())
  userId       String
  accountId    String
  name         String
  path         String
  syncedAt     DateTime @default(now())

  containers GTMContainerCache[]

  @@unique([userId, accountId])
  @@index([userId])
}

model GTMContainerCache {
  id            String   @id @default(cuid())
  userId        String
  accountId     String
  containerId   String
  name          String
  publicId      String
  usageContext  String   // JSON array
  domainName    String?
  path          String
  syncedAt      DateTime @default(now())

  account       GTMAccountCache @relation(fields: [userId, accountId], references: [userId, accountId], onDelete: Cascade)
  workspaces    GTMWorkspaceCache[]

  @@unique([userId, containerId])
  @@index([userId])
}

model GTMWorkspaceCache {
  id           String   @id @default(cuid())
  userId       String
  accountId    String
  containerId  String
  workspaceId  String
  name         String
  description  String?
  path         String
  syncedAt     DateTime @default(now())

  container    GTMContainerCache @relation(fields: [userId, containerId], references: [userId, containerId], onDelete: Cascade)
  tags         GTMTagCache[]
  triggers     GTMTriggerCache[]
  variables    GTMVariableCache[]

  @@unique([userId, accountId, containerId, workspaceId])
  @@index([userId])
}

model GTMTagCache {
  id               String   @id @default(cuid())
  userId           String
  accountId        String
  containerId      String
  workspaceId      String
  tagId            String
  name             String
  type             String
  parameter        String?  // JSON
  firingTriggerId  String?  // JSON array
  blockingTriggerId String? // JSON array
  paused           Boolean
  path             String
  syncedAt         DateTime @default(now())

  workspace GTMWorkspaceCache @relation(fields: [userId, accountId, containerId, workspaceId], references: [userId, accountId, containerId, workspaceId], onDelete: Cascade)

  @@unique([userId, accountId, containerId, workspaceId, tagId])
  @@index([userId])
}

model GTMTriggerCache {
  id           String   @id @default(cuid())
  userId       String
  accountId    String
  containerId  String
  workspaceId  String
  triggerId    String
  name         String
  type         String
  parameter    String?  // JSON
  filter       String?  // JSON
  path         String
  syncedAt     DateTime @default(now())

  workspace GTMWorkspaceCache @relation(fields: [userId, accountId, containerId, workspaceId], references: [userId, accountId, containerId, workspaceId], onDelete: Cascade)

  @@unique([userId, accountId, containerId, workspaceId, triggerId])
  @@index([userId])
}

model GTMVariableCache {
  id          String   @id @default(cuid())
  userId      String
  accountId   String
  containerId String
  workspaceId String
  variableId  String
  name        String
  type        String
  parameter   String?  // JSON
  path        String
  syncedAt    DateTime @default(now())

  workspace GTMWorkspaceCache @relation(fields: [userId, accountId, containerId, workspaceId], references: [userId, accountId, containerId, workspaceId], onDelete: Cascade)

  @@unique([userId, accountId, containerId, workspaceId, variableId])
  @@index([userId])
}
